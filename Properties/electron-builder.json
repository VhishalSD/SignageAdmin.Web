{
  "appId": "nl.signagebeheer.app",
  "productName": "Signage Beheer",
  "directories": {
    "output": "bin/Desktop"
  },
  "files": [
    "**/*"
  ],
  "win": {
    "icon": "Properties/AppIcon.ico",
    "target": [
      "nsis"
    ],
    "artifactName": "${productName}-Setup-${version}.${ext}"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "perMachine": false,
    "installerIcon": "Properties/AppIcon.ico",
    "uninstallerIcon": "Properties/AppIcon.ico",
    "installerHeaderIcon": "Properties/AppIcon.ico"
  }
}