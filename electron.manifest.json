{
  "executable": "SignageAdmin.Web",
  "splashscreen": {
    "imageFile": ""
  },
  "name": "signage-beheer",
  "author": "Vhishal Tewari",
  "singleInstance": false,
  "environment": "Production",
  "build": {
    "appId": "nl.reliplan.signagebeheer",
    "productName": "Signage Beheer",
    "copyright": "Copyright © 2026 Vhishal Tewari",
    "buildVersion": "1.0.0",
    "win": {
      "icon": "bin/Properties/AppIcon.ico"
    },
    "compression": "maximum",
    "directories": {
      "output": "../../../bin/Desktop"
    },
    "extraResources": [
      {
        "from": "./bin",
        "to": "bin",
        "filter": [ "**/*" ]
      }
    ],
    "files": [
      {
        "from": "./ElectronHostHook/node_modules",
        "to": "ElectronHostHook/node_modules",
        "filter": [ "**/*" ]
      },
      "**/*"
    ]
  }
}