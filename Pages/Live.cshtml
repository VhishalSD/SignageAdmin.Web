@page
@model PrivacyModel
@{
    ViewData["Title"] = "Preview";
    var previewVersion = DateTimeOffset.UtcNow.ToUnixTimeSeconds();
}

<style>
    .preview-shell {
        background: #111;
        border-radius: 0.75rem;
        overflow: hidden;
        padding: 0.5rem;
    }

    .preview-stage {
        width: 100%;
        display: flex;
        justify-content: center;
        align-items: flex-start;
        overflow: hidden;
    }

    .preview-frame {
        width: 1080px;
        height: 1920px;
        border: 0;
        background: #111;
        transform-origin: top center;
        display: block;
    }

    .preview-page-title {
        color: #f8fafc;
    }

    .preview-page-subtitle {
        color: #d1d5db;
        font-weight: 500;
        margin-bottom: 0;
    }

    .preview-info-card {
        background: rgba(15, 15, 18, 0.58);
        border: 1px solid rgba(255, 255, 255, 0.08) !important;
        box-shadow: 0 16px 36px rgba(0, 0, 0, 0.18);
        backdrop-filter: blur(14px) saturate(150%);
        -webkit-backdrop-filter: blur(14px) saturate(150%);
    }

    .preview-info-card .card-body,
    .preview-info-card .fw-semibold {
        color: #f8fafc;
    }

    .preview-info-card .text-muted {
        color: #d1d5db !important;
    }
</style>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="mb-1 preview-page-title">Voorbeeld</h1>
            <p class="preview-page-subtitle">Deze pagina gebruikt dezelfde gegevens als het beheerscherm.</p>
        </div>
        <a asp-page="/Index" class="btn btn-secondary">Terug naar beheer</a>
    </div>

    <div class="card border-0 shadow-sm mb-4 preview-info-card">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                <div>
                    <div class="fw-semibold">Live voorbeeld</div>
                    <div class="text-muted small">Hier zie je direct wat er op dit moment op het scherm wordt weergegeven.</div>
                </div>
                <span class="badge bg-dark">Live gekoppeld</span>
            </div>
        </div>
    </div>

    <div class="preview-shell border shadow-sm">
        <div id="previewStage" class="preview-stage">
            <iframe
                id="previewFrame"
                class="preview-frame"
                src="/preview/index.html?v=@previewVersion"
                title="Signage preview">
            </iframe>
        </div>
    </div>
</div>

<script>
    function fitPreviewFrame() {
        var stage = document.getElementById('previewStage');
        var frame = document.getElementById('previewFrame');

        if (!stage || !frame) {
            return;
        }

        var baseWidth = 1080;
        var baseHeight = 1920;
        var availableWidth = stage.clientWidth;
        var availableHeight = window.innerHeight * 0.88;
        var scale = Math.min(availableWidth / baseWidth, availableHeight / baseHeight);

        if (!isFinite(scale) || scale <= 0) {
            scale = 1;
        }

        frame.style.transform = 'scale(' + scale + ')';
        stage.style.height = (baseHeight * scale) + 'px';
    }

    window.addEventListener('load', fitPreviewFrame);
    window.addEventListener('resize', fitPreviewFrame);
</script>